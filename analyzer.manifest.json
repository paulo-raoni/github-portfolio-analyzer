{
  "name": "github-portfolio-analyzer",
  "version": "1.4.1",
  "commands": [
    { "id": "analyze" },
    { "id": "ingest-ideas" },
    { "id": "build-portfolio" },
    {
      "id": "report",
      "flags": [
        "--policy",
        "--explain",
        "--output",
        "--format",
        "--quiet",
        "--presentation-overrides"
      ]
    }
  ],
  "outputs": [
    "output/inventory.json",
    "output/portfolio.json",
    "output/portfolio-report.json"
  ],
  "schemas": {
    "portfolioReport": "schemas/portfolio-report.schema.json"
  }
}
